# AI Chief of Staff — Environment Variables
# Copy this file to .env and fill in your values

# ─── Option 1: AI Studio API key (recommended — simplest setup) ─────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Option 2: Vertex AI via ADC (if you already have GCP credentials) ──────
# Uncomment these if you use Application Default Credentials / service account
# (These are already set in pbkyc .env)
# PROJECT_ID=your-gcp-project-id
# LOCATION=us-central1

# ─── Optional: Model overrides ───────────────────────────────────────────────
# TRIAGE_MODEL=gemini-2.0-flash
# REPLY_MODEL=gemini-2.5-flash-preview-04-17
